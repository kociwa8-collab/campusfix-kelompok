APP_NAME=CampusFix
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
# Railway Postgres usually provides DATABASE_URL and PG* variables.
# If they are not injected automatically, map them from the database service:
# DB_HOST=${{campusfix-kelompok-db.PGHOST}}
# DB_PORT=${{campusfix-kelompok-db.PGPORT}}
# DB_DATABASE=${{campusfix-kelompok-db.PGDATABASE}}
# DB_USERNAME=${{campusfix-kelompok-db.PGUSER}}
# DB_PASSWORD=${{campusfix-kelompok-db.PGPASSWORD}}
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@campusfix.local"
MAIL_FROM_NAME="${APP_NAME}"
